# Project Specific - Large Data and Models
# (MNIST raw images are included as requested for training tasks)

# Exclude potential large model weights/checkpoints
*.pt
*.pth
*.ckpt

# Allow results and smaller data files
# (The user wants to push results that are not big size)
# Based on discovery, most .npz, .csv, .json, and .png are < 1MB.

# Redundant but safe: ignore common large extensions if they appear
*.h5
*.onnx

# Allow everything else by default, but ignore known large/temp dirs
!data/
!runs/
!mnist_ftle_result/

# Re-ignore temporary or redundant files within those directories
runs/jobs/**/logs/*.log
mnist_ftle_result/**/.DS_Store
runs/**/.DS_Store
data/**/.DS_Store
